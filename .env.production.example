# ─── Base de datos ────────────────────────────────────────────
DB_USER=dataheart
DB_PASSWORD=CAMBIAR_password_segura
DB_NAME=dataheart_sc

# ─── JWT ──────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=CAMBIAR_jwt_secret_muy_largo

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Generar con: openssl rand -hex 32
REDIS_PASSWORD=CAMBIAR_redis_password

# ─── Shopify ──────────────────────────────────────────────────
# Dashboard Shopify → Configuración → Notificaciones → Webhooks
SHOPIFY_WEBHOOK_SECRET=CAMBIAR_shopify_secret

# ─── Wompi ────────────────────────────────────────────────────
# Dashboard Wompi → Desarrolladores → Llaves de integridad
WOMPI_INTEGRITY_KEY=CAMBIAR_wompi_integrity_key

# ─── PayU ─────────────────────────────────────────────────────
# Dashboard PayU → Configuración → Configuración técnica
PAYU_API_KEY=CAMBIAR_payu_api_key
PAYU_MERCHANT_ID=CAMBIAR_payu_merchant_id

# ─── SMTP (correo automático) ─────────────────────────────────
# Ejemplo con Gmail: habilitar "App passwords" en cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@santiagocorazon.org
SMTP_PASS=CAMBIAR_app_password_gmail
EMAIL_FROM="Fundación Santiago Corazón <correo@santiagocorazon.org>"
