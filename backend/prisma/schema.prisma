// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String           @id @default(uuid())
  name     String           @unique
  keyName  String           @unique @map("key_name")
  roles    RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String              @map("password_hash")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  roleId             String              @map("role_id")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  role               Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  ordersCreated      Order[]             @relation("OrdersCreatedByUser")
  inventoryMovements InventoryMovement[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  details   String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model ClientDonor {
  id           String     @id @default(uuid())
  name         String
  docType      String     @map("doc_type") // Cédula, NIT, etc.
  docNumber    String     @unique @map("doc_number")
  phone        String?
  email        String?
  address      String?
  city         String?
  commune      String?
  neighborhood String?
  status       String     @default("Activo") // Activo, Inactivo
  historicalId String?    @map("historical_id") // ID original de Access
  createdAt    DateTime   @default(now()) @map("created_at")
  orders       Order[]
  donations    Donation[]

  @@index([docNumber])
  @@index([email])
  @@map("clients_donors")
}

model Order {
  id              String      @id @default(uuid())
  clientId        String      @map("client_id")
  orderDate       DateTime    @default(now()) @map("order_date")
  status          String      @default("Recibido") // Recibido, En preparación, Despachado, Entregado
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  paymentStatus   String      @default("Pendiente") @map("payment_status") // Pendiente, Pagado
  source          String      @default("Manual") // Shopify, Manual, TiendaFísica
  createdByUserId String?     @map("created_by_user_id")
  client          ClientDonor @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser   User?       @relation("OrdersCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([clientId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

model Donation {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  amount         Decimal       @db.Decimal(12, 2)
  date           DateTime      @default(now())
  paymentGateway String        @map("payment_gateway") // Wompi, PayU, PayPal, Frecuenti
  transactionId  String        @unique @map("transaction_id")
  status         String        @default("Approved") // Approved, Pending, Declined
  campaign       String?
  concept        String?
  createdAt      DateTime      @default(now()) @map("created_at")
  client         ClientDonor   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  certificates   Certificate[]

  @@index([clientId])
  @@map("donations")
}

model Certificate {
  id                String   @id @default(uuid())
  donationId        String   @map("donation_id")
  certificateNumber Int      @unique @map("certificate_number") // Consecutivo único
  issueDate         DateTime @default(now()) @map("issue_date")
  pdfPath           String   @map("pdf_path")
  status            String   @default("Enviado") // Enviado, Pendiente
  donation          Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Product {
  id        String         @id @default(uuid())
  name      String
  sku       String         @unique
  stock     Int            @default(0)
  minStock  Int            @default(0) @map("min_stock")
  price     Decimal        @db.Decimal(12, 2)
  isActive  Boolean        @default(true) @map("is_active")
  items     OrderItem[]
  inputs    ProductInput[]
  movements InventoryMovement[] @relation("ProductMovements")

  @@map("products")
}

model Input {
  id        String         @id @default(uuid())
  name      String         @unique
  stock     Decimal        @default(0) @db.Decimal(12, 3) // Soporta kg/gr
  minStock  Decimal        @default(0) @map("min_stock") @db.Decimal(12, 3)
  unit      String         // Kg, Unidades, Metros
  products  ProductInput[]
  movements InventoryMovement[] @relation("InputMovements")

  @@map("inputs")
}

model Companion {
  id        String              @id @default(uuid())
  name      String              @unique
  stock     Int                 @default(0)
  minStock  Int                 @default(0) @map("min_stock")
  movements InventoryMovement[] @relation("CompanionMovements")

  @@map("companions")
}

model ProductInput {
  productId        String  @map("product_id")
  inputId          String  @map("input_id")
  quantityRequired Decimal @map("quantity_required") @db.Decimal(12, 3)
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  input            Input   @relation(fields: [inputId], references: [id], onDelete: Restrict)

  @@id([productId, inputId])
  @@map("product_inputs")
}

model InventoryMovement {
  id           String    @id @default(uuid())
  itemType     String    @map("item_type") // Producto, Insumo, Acompañante
  productId    String?   @map("product_id")
  inputId      String?   @map("input_id")
  companionId  String?   @map("companion_id")
  movementType String    @map("movement_type") // Entrada, Salida, Ajuste
  quantity     Decimal   @db.Decimal(12, 3)
  userId       String    @map("user_id")
  movementDate DateTime  @default(now()) @map("movement_date")
  description  String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product?  @relation("ProductMovements", fields: [productId], references: [id], onDelete: Cascade)
  input        Input?    @relation("InputMovements", fields: [inputId], references: [id], onDelete: Cascade)
  companion    Companion? @relation("CompanionMovements", fields: [companionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("inventory_movements")
}

model Beneficiary {
  id             String    @id @default(uuid())
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  docType        String    @map("doc_type")
  docNumber      String    @unique @map("doc_number")
  birthDate      DateTime  @map("birth_date")
  gender         String?
  phone          String?
  guardianName   String?   @map("guardian_name")
  guardianPhone  String?   @map("guardian_phone")
  address        String?
  city           String?
  commune        String?
  neighborhood   String?
  status         String    @default("Activo")
  historicalId   String?   @map("historical_id")
  enrollDate     DateTime  @default(now()) @map("enroll_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([docNumber])
  @@map("beneficiaries")
}

model Volunteer {
  id           String    @id @default(uuid())
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  docType      String    @map("doc_type")
  docNumber    String    @unique @map("doc_number")
  email        String?   @unique
  phone        String?
  role         String?   // Rol dentro de la fundación
  skills       String?   // Habilidades relevantes
  status       String    @default("Activo")
  joinDate     DateTime  @default(now()) @map("join_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([docNumber])
  @@map("volunteers")
}

model Provider {
  id           String    @id @default(uuid())
  name         String
  docType      String    @map("doc_type")  // NIT, Cédula
  docNumber    String    @unique @map("doc_number")
  contactName  String?   @map("contact_name")
  email        String?
  phone        String?
  address      String?
  city         String?
  category     String?   // Materia prima, Servicios, Logística
  status       String    @default("Activo")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([docNumber])
  @@map("providers")
}
