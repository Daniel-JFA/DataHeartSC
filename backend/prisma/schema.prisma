// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String           @id @default(uuid())
  name     String           @unique
  keyName  String           @unique @map("key_name")
  roles    RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String              @map("password_hash")
  firstName          String              @map("first_name")
  lastName           String              @map("last_name")
  roleId             String              @map("role_id")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  role               Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  ordersCreated      Order[]             @relation("OrdersCreatedByUser")
  inventoryMovements InventoryMovement[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  details   String?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model ClientDonor {
  id           String     @id @default(uuid())
  name         String
  docType      String     @map("doc_type") // Cédula, NIT, etc.
  docNumber    String     @unique @map("doc_number")
  phone        String?
  email        String?
  address      String?
  city         String?
  commune      String?
  neighborhood String?
  status       String     @default("Activo") // Activo, Inactivo
  historicalId String?    @map("historical_id") // ID original de Access
  createdAt    DateTime   @default(now()) @map("created_at")
  orders       Order[]
  donations    Donation[]

  @@index([docNumber])
  @@index([email])
  @@map("clients_donors")
}

model Order {
  id               String      @id @default(uuid())
  clientId         String      @map("client_id")
  orderDate        DateTime    @default(now()) @map("order_date")
  status           String      @default("Recibido") // Recibido, En preparación, Despachado, Entregado
  totalAmount      Decimal     @map("total_amount") @db.Decimal(12, 2)
  paymentStatus    String      @default("Pendiente") @map("payment_status") // Pendiente, Pagado
  source           String      @default("Manual") // Shopify, Manual, TiendaFísica, WhatsApp, Web
  orderType        String      @default("Venta") @map("order_type") // Venta, ReciboCaja, NotaCredito, Remision, Historico
  invoiceNumber    String?     @map("invoice_number") // Número original: "FV FSC 30265"
  canalAtencion    String?     @map("canal_atencion") // Sitio Web, WhatsApp, Tienda física, Correo, Interno, Frecuenti
  municipioEntrega String?     @map("municipio_entrega")
  domiciliario     String?
  createdByUserId  String?     @map("created_by_user_id")
  client           ClientDonor @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdByUser    User?       @relation("OrdersCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items            OrderItem[]

  @@index([clientId])
  @@index([invoiceNumber])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("order_items")
}

model Donation {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  amount         Decimal       @db.Decimal(12, 2)
  date           DateTime      @default(now())
  paymentGateway String        @map("payment_gateway") // Wompi, PayU, PayPal, Frecuenti
  transactionId  String        @unique @map("transaction_id")
  status         String        @default("Approved") // Approved, Pending, Declined
  campaign       String?
  concept        String?
  createdAt      DateTime      @default(now()) @map("created_at")
  client         ClientDonor   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  certificates   Certificate[]

  @@index([clientId])
  @@map("donations")
}

model Certificate {
  id                String   @id @default(uuid())
  donationId        String   @map("donation_id")
  certificateNumber Int      @unique @map("certificate_number") // Consecutivo único
  issueDate         DateTime @default(now()) @map("issue_date")
  pdfPath           String   @map("pdf_path")
  status            String   @default("Enviado") // Enviado, Pendiente
  donation          Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Product {
  id              String         @id @default(uuid())
  name            String
  sku             String         @unique
  stock           Int            @default(0)
  minStock        Int            @default(0) @map("min_stock")
  price           Decimal        @db.Decimal(12, 2)
  isActive        Boolean        @default(true) @map("is_active")
  categoryName    String?        @map("category_name")    // Categoría del Excel: Donaciones, Productos, Eventos…
  subcategoryName String?        @map("subcategory_name") // Subcategoría: Bonos de Pésame, Plantas…
  externalId      String?        @unique @map("external_id") // id_producto original del Excel
  items           OrderItem[]
  inputs          ProductInput[]
  movements       InventoryMovement[] @relation("ProductMovements")

  @@map("products")
}

model Input {
  id        String         @id @default(uuid())
  name      String         @unique
  stock     Decimal        @default(0) @db.Decimal(12, 3) // Soporta kg/gr
  minStock  Decimal        @default(0) @map("min_stock") @db.Decimal(12, 3)
  unit      String         // Kg, Unidades, Metros
  products  ProductInput[]
  movements InventoryMovement[] @relation("InputMovements")

  @@map("inputs")
}

model Companion {
  id        String              @id @default(uuid())
  name      String              @unique
  stock     Int                 @default(0)
  minStock  Int                 @default(0) @map("min_stock")
  movements InventoryMovement[] @relation("CompanionMovements")

  @@map("companions")
}

model ProductInput {
  productId        String  @map("product_id")
  inputId          String  @map("input_id")
  quantityRequired Decimal @map("quantity_required") @db.Decimal(12, 3)
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  input            Input   @relation(fields: [inputId], references: [id], onDelete: Restrict)

  @@id([productId, inputId])
  @@map("product_inputs")
}

model InventoryMovement {
  id           String    @id @default(uuid())
  itemType     String    @map("item_type") // Producto, Insumo, Acompañante
  productId    String?   @map("product_id")
  inputId      String?   @map("input_id")
  companionId  String?   @map("companion_id")
  movementType String    @map("movement_type") // Entrada, Salida, Ajuste
  quantity     Decimal   @db.Decimal(12, 3)
  userId       String    @map("user_id")
  movementDate DateTime  @default(now()) @map("movement_date")
  description  String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product?  @relation("ProductMovements", fields: [productId], references: [id], onDelete: Cascade)
  input        Input?    @relation("InputMovements", fields: [inputId], references: [id], onDelete: Cascade)
  companion    Companion? @relation("CompanionMovements", fields: [companionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("inventory_movements")
}

model Beneficiary {
  id             String    @id @default(uuid())

  // -- Identificación --
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  docType        String    @map("doc_type")   // Cédula de Ciudadanía, Registro Civil, Tarjeta de Identidad, Permiso Especial Permanencia, Menor sin Identificación, NO ADRES
  docNumber      String    @unique @map("doc_number")
  birthDate      DateTime? @map("birth_date")
  birthCity      String?   @map("birth_city")
  nationality    String?   @default("Colombiana")
  gender         String?   // Masculino, Femenino
  etnia          String?
  condicion      String?
  deceasedDate   DateTime? @map("deceased_date") // null = vivo; fecha = fallecido

  // -- Contacto --
  phone          String?   // Teléfono fijo
  celular        String?   // Celular
  email          String?
  address        String?
  city           String?
  department     String?
  commune        String?
  neighborhood   String?
  isDisplaced    Boolean?  @default(false) @map("is_displaced")

  // -- Salud --
  eps               String?
  regimen           String?  // Subsidiado, Contributivo, Prepagada
  sisbenGroup       String?  @map("sisben_group") // A, B, C, D
  diagnostico       String?  // Cardiopatía principal
  otherDiagnosis    String?  @map("other_diagnosis") // Otro diagnóstico, discapacidad o limitación
  tratadoEn         String?  @map("tratado_en")     // Ciudad donde ha sido tratado
  clinicaHospital   String?  @map("clinica_hospital")

  // -- Familia: Madre --
  motherName           String?  @map("mother_name")
  motherDocNumber      String?  @map("mother_doc_number")
  motherPhone          String?  @map("mother_phone")
  motherOccupation     String?  @map("mother_occupation")
  motherEducation      String?  @map("mother_education")   // Sin escolaridad, Primaria, Bachiller, Técnico, Profesional
  motherProfession     String?  @map("mother_profession")
  motherLivesWithChild Boolean? @map("mother_lives_with_child")
  motherRespondsEcon   Boolean? @map("mother_responds_econ")

  // -- Familia: Padre --
  fatherName           String?  @map("father_name")
  fatherDocNumber      String?  @map("father_doc_number")
  fatherPhone          String?  @map("father_phone")
  fatherOccupation     String?  @map("father_occupation")
  fatherEducation      String?  @map("father_education")
  fatherProfession     String?  @map("father_profession")
  fatherLivesWithChild Boolean? @map("father_lives_with_child")
  fatherRespondsEcon   Boolean? @map("father_responds_econ")

  // -- Familia: Hermanos y Cuidador --
  hasSiblings           Boolean? @map("has_siblings")
  numSiblings           Int?     @map("num_siblings")
  siblingsData          Json?    @map("siblings_data")       // [{edad, convivenConEllos}]
  caregiverName         String?  @map("caregiver_name")
  caregiverRelationship String?  @map("caregiver_relationship")
  caregiverPhone        String?  @map("caregiver_phone")

  // -- Vivienda y Demografía --
  zone                  String?  // Rural, Urbano
  housingType           String?  @map("housing_type")          // Arrendada, Propia, Familiar
  housingStrata         Int?     @map("housing_strata")        // 1–6
  publicServices        Json?    @map("public_services")       // ["Energía eléctrica", "Agua potable", ...]
  publicTransportNearby Boolean? @map("public_transport_nearby")
  numPeopleInHome       Int?     @map("num_people_in_home")

  // -- Economía --
  incomeSource       String?  @map("income_source")
  receivesGovSubsidy Boolean? @map("receives_gov_subsidy")
  govSubsidyType     String?  @map("gov_subsidy_type")

  // -- Campos legacy (compatibilidad con seed inicial) --
  guardianName   String?  @map("guardian_name")
  guardianPhone  String?  @map("guardian_phone")

  // -- Meta --
  comoSeEntero   String?  @map("como_se_entero")
  status         String   @default("Activo") // Activo, Inactivo, Fallecido
  historicalId   String?  @map("historical_id")
  enrollDate     DateTime @default(now()) @map("enroll_date")
  lastUpdatedAt  DateTime? @map("last_updated_at") // Fecha de Actualización del Excel
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ayudas         Ayuda[]

  @@index([docNumber])
  @@map("beneficiaries")
}

model Ayuda {
  id                   String      @id @default(uuid())
  beneficiaryId        String      @map("beneficiary_id")
  fecha                DateTime
  tipoSolicitud        String      @map("tipo_solicitud") // Transporte, Copagos, Medicamento, Alimentación, Alojamiento, Cita Médica, Ayudas Diagnósticas, Pañales y otros, Ropa y Jugetes, Recreación, Capacitación, Apoyo emprendimientos, Asesorias, Empleo, Servicio Funerario, Otra
  personasBeneficiadas Int         @default(1) @map("personas_beneficiadas")
  justificacion        String?
  valor                Decimal     @default(0) @db.Decimal(12, 2)
  estado               String      @default("Pendiente") // Pendiente, Resuelta
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  beneficiary          Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Restrict)

  @@index([beneficiaryId])
  @@index([fecha])
  @@map("ayudas")
}

model Volunteer {
  id           String    @id @default(uuid())
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  docType      String    @map("doc_type")
  docNumber    String    @unique @map("doc_number")
  email        String?   @unique
  phone        String?
  role         String?   // Rol dentro de la fundación
  skills       String?   // Habilidades relevantes
  status       String    @default("Activo")
  joinDate     DateTime  @default(now()) @map("join_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([docNumber])
  @@map("volunteers")
}

model Provider {
  id                         String    @id @default(uuid())
  // Base
  name                       String
  docType                    String    @map("doc_type")
  docNumber                  String    @unique @map("doc_number")
  contactName                String?   @map("contact_name")
  email                      String?
  phone                      String?
  address                    String?
  city                       String?
  department                 String?
  category                   String?
  status                     String    @default("Pendiente")
  // Sección 1 - Tipo solicitud
  tipoSolicitud              String?   @map("tipo_solicitud")
  tipoSolicitudOtro          String?   @map("tipo_solicitud_otro")
  // Sección 2 - Naturaleza
  naturaleza                 String?
  formaPagoTipo              String?   @map("forma_pago_tipo")
  diasCredito                String?   @map("dias_credito")
  // Sección 3 - Persona Natural
  lugarExpedicion            String?   @map("lugar_expedicion")
  fechaExpedicion            String?   @map("fecha_expedicion")
  nationality                String?
  departamentoResidencia     String?   @map("departamento_residencia")
  ciudadResidencia           String?   @map("ciudad_residencia")
  telefonoDomicilio          String?   @map("telefono_domicilio")
  primerApellido             String?   @map("primer_apellido")
  segundoApellido            String?   @map("segundo_apellido")
  primerNombre               String?   @map("primer_nombre")
  segundoNombre              String?   @map("segundo_nombre")
  // Sección 4 - Persona Jurídica
  nit                        String?
  digitoVerificacion         String?   @map("digito_verificacion")
  correoEmpresa              String?   @map("correo_empresa")
  telefonoEmpresa            String?   @map("telefono_empresa")
  direccionOficina           String?   @map("direccion_oficina")
  repLegal                   Json?     @map("rep_legal")
  // Sección 5 - Actividad económica
  actividadTipo              String?   @map("actividad_tipo")
  actividadOtro              String?   @map("actividad_otro")
  codigoCIIU                 String?   @map("codigo_ciiu")
  descripcionActividad       String?   @map("descripcion_actividad")
  // Sección 6 - Información de pagos
  formaPago                  String?   @map("forma_pago")
  tipoCuenta                 String?   @map("tipo_cuenta")
  numeroCuenta               String?   @map("numero_cuenta")
  diasPago                   String?   @map("dias_pago")
  // Sección 7 - Contacto de facturación
  factNombre                 String?   @map("fact_nombre")
  factCargo                  String?   @map("fact_cargo")
  factTelefono               String?   @map("fact_telefono")
  factExt                    String?   @map("fact_ext")
  factCelular                String?   @map("fact_celular")
  factEmail                  String?   @map("fact_email")
  // Sección 8 - Referencias comerciales
  referencias                Json?
  // Sección 9 - Accionistas
  accionistas                Json?
  // Sección 10 - Información financiera
  totalActivos               String?   @map("total_activos")
  totalPasivos               String?   @map("total_pasivos")
  totalPatrimonio            String?   @map("total_patrimonio")
  ingresosMensuales          String?   @map("ingresos_mensuales")
  egresosMensuales           String?   @map("egresos_mensuales")
  otrosIngresosMensuales     String?   @map("otros_ingresos_mensuales")
  conceptoOtrosIngresos      String?   @map("concepto_otros_ingresos")
  // Sección 11 - Operaciones internacionales
  operaciones                Json?
  // Sección 12 - PPE
  manejaRecursosPublicos     Boolean?  @map("maneja_recursos_publicos")
  tieneReconocimientoPublico Boolean?  @map("tiene_reconocimiento_publico")
  ejercePoder                Boolean?  @map("ejerce_poder")
  esFamiliarPPE              Boolean?  @map("es_familiar_ppe")
  familiarPPEInfo            String?   @map("familiar_ppe_info")
  // Sección 13 - Declaraciones
  aceptaDeclaracion          Boolean?  @map("acepta_declaracion")
  aceptaTratamientoDatos     Boolean?  @map("acepta_tratamiento_datos")
  // Rutas de archivos adjuntos
  rutPath                    String?   @map("rut_path")
  camaraComercioPath         String?   @map("camara_comercio_path")
  certBancariaPath           String?   @map("cert_bancaria_path")
  formatoProveedorPath       String?   @map("formato_proveedor_path")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  @@index([docNumber])
  @@map("providers")
}
